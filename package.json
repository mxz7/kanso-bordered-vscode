{
	"categories": [
		"Themes"
	],
	"contributes": {
		"grammars": [
			{
				"injectTo": [
					"source.python"
				],
				"path": "./syntaxes/python-error-keywords.tmLanguage.json",
				"scopeName": "source.python.kanso-error-keywords"
			}
		],
		"themes": [
			{
				"label": "Kanso Bordered Zen",
				"uiTheme": "vs-dark",
				"path": "./themes/kanso-zen.json"
			},
			{
				"label": "Kanso Bordered Ink",
				"uiTheme": "vs-dark",
				"path": "./themes/kanso-ink.json"
			},
			{
				"label": "Kanso Bordered Mist",
				"uiTheme": "vs-dark",
				"path": "./themes/kanso-mist.json"
			},
			{
				"label": "Kanso Bordered Pearl",
				"uiTheme": "vs",
				"path": "./themes/kanso-pearl.json"
			}
		]
	},
	"description": "A quietly structured fork of Kanso with subtle borders across the VS Code workbench.",
	"devDependencies": {
		"@vscode/vsce": "^3.2.1"
	},
	"displayName": "Kanso Bordered",
	"engines": {
		"vscode": "^1.77.0"
	},
	"homepage": "https://github.com/mxz7/kanso-bordered-vscode#readme",
	"icon": "assets/kanso-bordered-icon.png",
	"keywords": [
		"kanso",
		"kanagawa",
		"color",
		"theme",
		"vscode",
		"dark",
		"light",
		"zen",
		"ink",
		"pearl"
	],
	"license": "MIT",
	"name": "kanso-bordered-vscode",
	"packageManager": "pnpm@11.13.1",
	"publisher": "mxz7",
	"repository": {
		"type": "git",
		"url": "https://github.com/mxz7/kanso-bordered-vscode.git"
	},
	"bugs": {
		"url": "https://github.com/mxz7/kanso-bordered-vscode/issues"
	},
	"scripts": {
		"package": "vsce package --no-dependencies",
		"publish": "vsce publish --no-dependencies"
	},
	"version": "1.1.1"
}
